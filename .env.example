# ── 复制为 .env，并在 Vercel 项目设置里逐项填入 ──

# 数据库：Neon 的 Postgres 连接串（Neon 控制台 → Connection string）
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require"

# 会话签名密钥：换成一段长随机字符串（如 openssl rand -hex 32）
JWT_SECRET="请换成强随机字符串"

# AI（DeepSeek）
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com/v1"
AI_DEFAULT_MODEL="deepseek-chat"

# 应用地址：线上填你的 Vercel 域名（用于验证码邮件等），如 https://founderlab.vercel.app
APP_URL="https://你的域名.vercel.app"

# 邮箱 SMTP（注册/改密验证码）。163 示例：HOST=smtp.163.com PORT=465；
# SMTP_PASS 填客户端授权码。云服务器发 163 可能被限流，收不到就改用 Resend 等。
SMTP_HOST="smtp.163.com"
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""
