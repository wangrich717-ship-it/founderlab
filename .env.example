# ── 复制为 .env，并在 Vercel 项目设置里逐项填入 ──

# 数据库（Neon）。两条只差 host 里的 -pooler：
# DATABASE_URL 用「带 -pooler」的 pooler host（运行时连接池）
# DIRECT_URL   用「不带 -pooler」的普通 host（建表/迁移）
DATABASE_URL="postgresql://neondb_owner:PASSWORD@ep-xxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://neondb_owner:PASSWORD@ep-xxx.REGION.aws.neon.tech/neondb?sslmode=require"

# 会话签名密钥：换成一段长随机字符串（如 openssl rand -hex 32）
JWT_SECRET="请换成强随机字符串"

# AI（DeepSeek）
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com/v1"
AI_DEFAULT_MODEL="deepseek-chat"

# 应用地址：线上填你的 Vercel 域名（用于验证码邮件等），如 https://founderlab.vercel.app
APP_URL="https://你的域名.vercel.app"

# 发信（验证码）。推荐用 Brevo（HTTP API，对 Vercel 友好，不用买域名）：
# 1) brevo.com 注册 → Settings → Senders 里验证你现有的邮箱当发件人
# 2) Settings → SMTP & API → API Keys 生成一个 key
# 3) BREVO_API_KEY 填 key，MAIL_FROM 填你验证过的发件邮箱
BREVO_API_KEY=""
MAIL_FROM=""
MAIL_FROM_NAME="创业者手札"

# 备用：SMTP（本地开发或不用 Brevo 时）。163 示例：HOST=smtp.163.com PORT=465，
# SMTP_PASS 填客户端授权码。注意 163 从云服务器发常被拦。
SMTP_HOST=""
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""
